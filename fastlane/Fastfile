def decode_base64_to_file(value, path)
  File.open(path, 'wb') { |f| f.write(Base64.decode64(value)) }
end

platform :ios do
  desc 'Build and upload iOS app to TestFlight'
  lane :beta do
    require 'base64'
    require 'tmpdir'

    app_identifier = ENV.fetch('APP_IDENTIFIER', 'com.hormuzpass.app')

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch('APP_STORE_CONNECT_API_KEY_ID'),
      issuer_id: ENV.fetch('APP_STORE_CONNECT_ISSUER_ID'),
      key_content: Base64.decode64(ENV.fetch('APP_STORE_CONNECT_API_KEY_BASE64')),
      is_key_content_base64: false
    )

    Dir.mktmpdir('fastlane-signing') do |dir|
      if ENV['IOS_SIGNING_CERT_BASE64'] && ENV['IOS_SIGNING_CERT_PASSWORD']
        cert_path = File.join(dir, 'signing.p12')
        decode_base64_to_file(ENV['IOS_SIGNING_CERT_BASE64'], cert_path)
        import_certificate(
          certificate_path: cert_path,
          certificate_password: ENV['IOS_SIGNING_CERT_PASSWORD']
        )
      end

      if ENV['IOS_PROVISION_PROFILE_BASE64']
        profile_path = File.join(dir, 'profile.mobileprovision')
        decode_base64_to_file(ENV['IOS_PROVISION_PROFILE_BASE64'], profile_path)
        install_provisioning_profile(path: profile_path)
      end
    end

    export_options = {}
    if ENV['IOS_PROVISION_PROFILE_NAME']
      export_options[:provisioningProfiles] = {
        app_identifier => ENV['IOS_PROVISION_PROFILE_NAME']
      }
    end

    build_app(
      workspace: 'ios/App/App.xcworkspace',
      scheme: 'App',
      configuration: 'Release',
      clean: true,
      export_method: 'app-store',
      output_directory: 'build',
      output_name: 'HormuzPass.ipa',
      export_options: export_options.empty? ? nil : export_options
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: 'build/HormuzPass.ipa',
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
